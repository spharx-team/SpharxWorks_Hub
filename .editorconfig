# EditorConfig is awesome: https://EditorConfig.org

# 顶级配置文件
root = true

# 通用文件设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C/C++ 文件设置
[*.{c,h,cpp,hpp,cc,hxx}]
indent_style = space
indent_size = 4
tab_width = 4

# Go 文件设置
[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

# Rust 文件设置
[*.rs]
indent_style = space
indent_size = 4
tab_width = 4

# Python 文件设置
[*.py]
indent_style = space
indent_size = 4
tab_width = 4
max_line_length = 88

# JavaScript/TypeScript 文件设置
[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2
tab_width = 2

# JSON 文件设置
[*.json]
indent_style = space
indent_size = 2
tab_width = 2

# YAML/YML 文件设置
[*.{yml,yaml}]
indent_style = space
indent_size = 2
tab_width = 2

# Markdown 文件设置
[*.md]
indent_style = space
indent_size = 2
tab_width = 2
trim_trailing_whitespace = false

# Makefile 文件设置
[Makefile]
indent_style = tab
tab_width = 4

# Shell 脚本文件设置
[*.sh]
indent_style = space
indent_size = 2
tab_width = 2

# Java 文件设置
[*.java]
indent_style = space
indent_size = 4
tab_width = 4

# XML 文件设置
[*.xml]
indent_style = space
indent_size = 2
tab_width = 2

# HTML 文件设置
[*.{html,htm}]
indent_style = space
indent_size = 2
tab_width = 2

# CSS 文件设置
[*.css]
indent_style = space
indent_size = 2
tab_width = 2

# SQL 文件设置
[*.sql]
indent_style = space
indent_size = 2
tab_width = 2

# 配置文件设置
[*.{ini,cfg,conf}]
indent_style = space
indent_size = 2
tab_width = 2

# Dockerfile 设置
[Dockerfile]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：CMakeLists.txt 和 .cmake 文件
[CMakeLists.txt]
indent_style = space
indent_size = 2
tab_width = 2

[*.cmake]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.gitattributes
[.gitattributes]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.gitignore
[.gitignore]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.gitmodules
[.gitmodules]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.editorconfig 自身
[.editorconfig]
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = off

# 特殊文件：.env 文件
[.env*]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：pyproject.toml
[pyproject.toml]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：requirements.txt
[requirements*.txt]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：Docker Compose
[docker-compose*.yml]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.pre-commit-config.yaml
[.pre-commit-config.yaml]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.clang-format, .clang-tidy
[.clang-format]
indent_style = space
indent_size = 2
tab_width = 2

[.clang-tidy]
indent_style = space
indent_size = 2
tab_width = 2

# 特殊文件：.travis.yml, .github/workflows/*.yml
[.travis.yml]
indent_style = space
indent_size = 2
tab_width = 2

[.github/workflows/*.yml]
indent_style = space
indent_size = 2
tab_width = 2

# Docker 相关文件
[docker-entrypoint.sh]
indent_style = space
indent_size = 2
tab_width = 2
